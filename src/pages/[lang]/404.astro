---
import { defaultLang, languages, useTranslations } from "../../assets/i18n/utils";
import Layout from "../../layouts/Layout.astro";
import BadRequestContent from "../../components/BadRequestContent.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLang = lang as "es" | "de";
const translate = useTranslations(currentLang);
---

<Layout currentLang={currentLang} translate={translate}>
  <BadRequestContent currentLang={currentLang} translate={translate} />
</Layout>
