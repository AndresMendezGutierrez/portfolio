---
import IconComponent from "./IconComponent.astro";

const { translate } = Astro.props;
---

<header class="flex flex-col gap-4 justify-center items-center sm:gap-8 lg:gap-10">
  <h1
    class="opacity-0 animate-slide-top [animation-delay:200ms] w-3/5 text-center text-5xl font-workbench sm:text-6xl lg:text-8xl"
  >
    {translate("intro_title")}
  </h1>

  <p
    class="opacity-0 animate-slide-top [animation-delay:400ms] text-lg sm:text-2xl lg:text-28 font-semibold lg:mt-2 lg:mb-1"
  >
    {translate("intro_subtitle")}
  </p>

  <span
    class="opacity-0 animate-slide-top [animation-delay:600ms] text-primary border border-primary font-regular px-3.5 py-3"
  >
    {translate("intro_status")}
  </span>
</header>

<a href="#about" class="absolute bottom-8 md:bottom-12 opacity-0 animate-fade-in [animation-delay:1s]">
  <IconComponent icon="down-icon" class="animate-slow-bounce w-19 h-19" />
</a>
