---
import IconComponent from "./IconComponent.astro";

const { translate } = Astro.props;
---

<header class="intro-container flex flex-col gap-4 justify-center items-center sm:gap-8 lg:gap-10">
  <h1 class="name w-3/5 text-center text-5xl font-workbench sm:text-6xl lg:text-8xl">
    {translate("intro_title")}
  </h1>
  <p class="qualification text-lg sm:text-2xl lg:text-28 font-semibold lg:mt-2 lg:mb-1">
    {translate("intro_subtitle")}
  </p>

  <span class="status-badge text-primary border border-primary font-regular px-3.5 py-3">
    {translate("intro_status")}
  </span>
</header>

<a href="#about" class="scroll-down absolute bottom-8 md:bottom-12">
  <IconComponent icon="down-icon" class="w-19 stroke-1" />
</a>

<style>
  @keyframes slideInFromTop {
    0% {
      opacity: 0;
      transform: translateY(-30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .intro-container > * {
    opacity: 0;
    animation: slideInFromTop 0.8s ease-out forwards;
  }

  .name {
    animation-delay: 0.2s;
  }
  .qualification {
    animation-delay: 0.4s;
  }
  .status-badge {
    animation-delay: 0.6s;
  }

  .scroll-down {
    opacity: 0;
    animation:
      fadeIn 1s ease-in forwards 1s,
      bounce 3s infinite;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  @keyframes bounce {
    0% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-15px);
    }
    100% {
      transform: translateY(0);
    }
  }
</style>
